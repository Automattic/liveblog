{
  "name": "liveblog",
  "description": "Liveblogging done right. Using WordPress",
  "version": "2.0.0",
  "author": "Automattic",
  "private": true,
  "devDependencies": {
    "@wordpress/i18n": "^6.10.0",
    "@wordpress/scripts": "^31.1.0",
    "sass-module-importer": "^1.4.0",
    "sass-mq": "^7.0.0"
  },
  "dependencies": {
    "@wordpress/api-fetch": "^7.45.0",
    "@wordpress/components": "^33.0.0",
    "@wordpress/dataviews": "^14.2.0",
    "@wordpress/element": "^6.45.0"
  },
  "scripts": {
    "build": "wp-scripts build",
    "start": "wp-scripts start",
    "dev": "wp-scripts start",
    "lint:js": "wp-scripts lint-js ./src",
    "lint:css": "wp-scripts lint-style \"src/**/*.scss\"",
    "test": "wp-scripts test-unit-js",
    "dist": "npm run build && composer install --no-dev --optimize-autoloader && rm -rf dist && mkdir -p dist/liveblog && rsync -r --exclude-from=.distignore . dist/liveblog/ && cd dist && zip -r liveblog.zip liveblog && cd .. && echo ' dist/liveblog.zip ready'"
  },
  "overrides": {
    "webpack-dev-server": "^5.2.1"
  }
}
